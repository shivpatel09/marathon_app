# --- Database ---
# Postgres connection string (Neon, Supabase, or local Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/marathon?schema=public"

# --- Auth.js ---
# Generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=""
# Base URL of the app (dev default below)
AUTH_URL="http://localhost:3000"

# --- Strava API ---
# Create an app at https://www.strava.com/settings/api
# Authorization Callback Domain in Strava settings must be: localhost
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
# Webhook auto-sync: any random string you choose; Strava echoes it back during
# subscription validation. Required only if you set up push subscriptions.
STRAVA_WEBHOOK_VERIFY_TOKEN=""

# --- Anthropic (weekly coaching report) ---
# Optional. Without it, the report still shows all metrics but uses a
# deterministic narrative instead of the AI-written one.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
