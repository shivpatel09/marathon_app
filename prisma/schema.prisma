// Phase 0 schema: Auth.js (NextAuth) models + synced Strava activities.
// Later phases add plan templates, scheduled workouts, check-ins, etc. (see spec §7).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (app runtime)
  directUrl = env("DIRECT_URL") // unpooled (migrations / db push)
}

// ---- Auth.js standard models ----

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  // nutrition profile (lightweight; see spec §9.4)
  weightKg             Float?
  heightCm             Float?
  age                  Int?
  maxHr                Int? // measured max HR; falls back to an age estimate
  sex                  Sex?
  bodyCompGoal         BodyCompGoal?
  weeklyWeightChangeKg Float? // target rate, e.g. -0.25 (negative = lose)
  baselineActivity     ActivityLevel?
  dietaryPrefs         String[]
  // Runalyze Personal API token (runalyze.com/settings/personal-api) —
  // used server-side only to pull race predictions for the Predictions tab
  runalyzeToken        String?
  accounts      Account[]
  sessions      Session[]
  activities    Activity[]
  planInstances UserPlanInstance[]
  checkIns      DailyCheckIn[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Synced Strava activities ----

model Activity {
  id             String   @id // Strava activity id (stringified)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  type           String   // sport_type, e.g. "Run", "TrailRun"
  startDate      DateTime
  distanceM      Float    // meters
  movingTime     Int      // seconds
  elapsedTime    Int      // seconds
  avgSpeed       Float?   // m/s
  avgHr          Float?
  totalElevation Float?   // meters
  raw            Json
  createdAt      DateTime @default(now())

  @@index([userId, startDate])
}

// ---- Training plan templates (the proven programs) ----
// Intensity is stored as an abstract `paceRef` in workout segments and resolved
// per-user from their goal time at plan-instance time (see src/lib/paces.ts).

model TrainingPlanTemplate {
  id          String      @id @default(cuid())
  key         String      @unique // stable slug, e.g. "pfitz-18-55"
  name        String // "Pfitzinger 18/55"
  author      String
  weeks       Int
  daysPerWeek Int
  peakMileage Int
  longRunCap  Int? // 16 for Hansons, null for Pfitz
  description String?
  mesocycles  Mesocycle[]
  instances   UserPlanInstance[]
}

model Mesocycle {
  id         String               @id @default(cuid())
  templateId String
  template   TrainingPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String // "Endurance", "Speed phase", "Taper"...
  startWeek  Int
  endWeek    Int
  order      Int
  workouts   WorkoutTemplate[]

  @@index([templateId])
}

model WorkoutTemplate {
  id          String      @id @default(cuid())
  mesocycleId String
  mesocycle   Mesocycle   @relation(fields: [mesocycleId], references: [id], onDelete: Cascade)
  weekIndex   Int // 1..weeks
  dayOfWeek   Int // 0 = Monday .. 6 = Sunday
  type        WorkoutType
  isDouble    Boolean     @default(false)
  label       String? // human-readable book prescription, e.g. "LT 9 mi w/ 20-25 min @ LT"
  segments    Json // [{ paceRef, value, unit, reps?, ... }]

  @@unique([mesocycleId, weekIndex, dayOfWeek])
  @@index([mesocycleId])
}

enum WorkoutType {
  RECOVERY
  EASY
  GENERAL_AEROBIC
  MEDIUM_LONG
  LONG
  MARATHON_PACE
  TEMPO_LT
  VO2MAX
  SPEED
  STRENGTH_INTERVALS
  STRIDES
  RACE
  TUNE_UP_RACE
  REST
  CROSS_TRAIN
}

// ---- Per-user plan instance + the generated dated schedule ----

model UserPlanInstance {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId   String
  template     TrainingPlanTemplate @relation(fields: [templateId], references: [id])
  raceDate     DateTime
  goalTimeSec  Int
  derivedPaces Json // snapshot of resolved paces at creation
  active       Boolean              @default(true)
  createdAt    DateTime             @default(now())
  scheduled    ScheduledWorkout[]

  @@index([userId])
}

model ScheduledWorkout {
  id                String           @id @default(cuid())
  planInstanceId    String
  planInstance      UserPlanInstance @relation(fields: [planInstanceId], references: [id], onDelete: Cascade)
  weekIndex         Int
  dayOfWeek         Int // 0 = Monday .. 6 = Sunday
  date              DateTime
  originalDate      DateTime // as first generated; for audit / constraint checks
  movedByUser       Boolean          @default(false)
  type              WorkoutType
  label             String? // human-readable book prescription
  plannedSegments   Json // segments with resolved pace (secPerMile) baked in
  targetRacePace    Float? // sec/mi, for TUNE_UP_RACE
  raceDistanceM     Float?
  status            WorkoutStatus    @default(PLANNED)
  matchedActivityId String?
  adherenceScore    Float?

  @@index([planInstanceId, date])
}

enum WorkoutStatus {
  PLANNED
  COMPLETED
  MISSED
  PARTIAL
}

// ---- Nutrition: lightweight daily check-in (estimate + correct) ----

model DailyCheckIn {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime // calendar day (midnight)
  weightKg     Float? // morning weigh-in; trend is what matters
  intakeSignal IntakeSignal?
  estCalories  Int? // optional rough self-report
  proteinHit   Boolean? // hit protein target?
  energyLevel  Int? // 1..5
  soreness     Int? // 1..5
  sleepHours   Float?
  notes        String?
  createdAt    DateTime      @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

enum Sex {
  MALE
  FEMALE
}

enum BodyCompGoal {
  MAINTAIN
  LOSE_FAT
  GAIN
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
}

enum IntakeSignal {
  UNDER
  ON_TARGET
  OVER
}

// ---- Strength library + phase-progressed sessions (spec §9.3) ----

model StrengthExercise {
  id           String          @id @default(cuid())
  key          String          @unique
  name         String
  pattern      MovementPattern
  equipment    String?
  isUnilateral Boolean         @default(false)
  cues         String?
}

model StrengthSessionTemplate {
  id    String @id @default(cuid())
  phase String // base | build | peak | taper
  slot  String // A | B
  name  String
  order Int
  items Json // [{ exerciseKey, sets, reps, note? }]

  @@unique([phase, slot])
}

enum MovementPattern {
  SQUAT
  HINGE
  LUNGE
  PUSH
  PULL
  CORE
  PLYO
  CALF
}
